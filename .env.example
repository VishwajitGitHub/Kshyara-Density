# KSHYARA CLI - Environment Variables
# Copy this file to .env and fill in your keys

# AI Provider API Keys
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
MISTRAL_API_KEY=
QWEN_API_KEY=

# System Configuration
KSHYARA_ENV=development
KSHYARA_DEBUG=false
KSHYARA_LOG_LEVEL=info

# Optional: Custom endpoints for enterprise/local models
CUSTOM_OPENAI_ENDPOINT=
CUSTOM_OLLAMA_ENDPOINT=http://localhost:11434
