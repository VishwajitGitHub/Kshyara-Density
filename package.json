    "test": "vitest",
    "clean": "node scripts/clean.js"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "tsx": "^4.7.1",
    "esbuild": "^0.20.1",
    "vitest": "^1.3.1",
    "prettier": "^3.2.5",
    "eslint": "^8.56.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react-hooks": "^4.6.0"
  }
}
